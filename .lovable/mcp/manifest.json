{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "fastlink-mcp",
      "version": "0.1.0",
      "title": "FastLink Global Wallet"
    },
    "tools": [
      {
        "name": "get_balances",
        "title": "Get balances",
        "description": "Returns the demo FastLink account's digital asset, fiat wallet, and card balances.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "convert_quote",
        "title": "Get conversion quote",
        "description": "Quote a zero-fee FX/crypto conversion between two supported currencies.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "from": {
              "type": "string",
              "minLength": 2,
              "maxLength": 6,
              "description": "Source currency, e.g. USDT, USD, SGD."
            },
            "to": {
              "type": "string",
              "minLength": 2,
              "maxLength": 6,
              "description": "Target currency, e.g. USDC, EUR, MYR."
            },
            "amount": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Amount in the source currency."
            }
          },
          "required": [
            "from",
            "to",
            "amount"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_cards",
        "title": "List cards",
        "description": "List the FastLink cards on the demo account with status, alias, and balance.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      }
    ]
  }
}
